<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fhtw.accuweatherapp.UIController">
   <top>
      <HBox prefHeight="24.0" prefWidth="580.0" BorderPane.alignment="CENTER">
         <children>
            <TextField fx:id="txt_field_city" prefHeight="25.0" prefWidth="302.0" promptText="City">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
            </TextField>
            <Button fx:id="btn_safe_favourite" mnemonicParsing="false" onAction="#onSafeFavourite" prefHeight="25.0" prefWidth="40.0" text="★" />
            <MenuButton fx:id="menu_user" mnemonicParsing="false" prefHeight="25.0" prefWidth="90.0" text="User">
              <items>
                <MenuItem fx:id="menu_item_moritz" mnemonicParsing="false" onAction="#onMoritz" text="Moritz" />
                <MenuItem fx:id="menu_item_jan" mnemonicParsing="false" onAction="#onJan" text="Jan" />
                  <MenuItem fx:id="menu_item_boris" mnemonicParsing="false" onAction="#onBoris" text="Boris" />
              </items>
            </MenuButton>
            <ComboBox fx:id="combox_last_used" prefHeight="25.0" prefWidth="90.0" promptText="Recently" />
            <Button fx:id="btn_search" mnemonicParsing="false" onAction="#onSearch" prefHeight="37.0" prefWidth="70.0" text="Search" />
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </HBox>
   </top>
   <opaqueInsets>
      <Insets />
   </opaqueInsets>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <TextArea fx:id="txt_field_cur_weather" editable="false" prefHeight="123.0" prefWidth="580.0" text="Aktulles Wetter">
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </TextArea>
            <HBox prefHeight="254.0" prefWidth="580.0">
               <children>
                  <TextArea fx:id="txt_field_day1" editable="false" prefHeight="200.0" prefWidth="200.0" text="Tag 1">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </TextArea>
                  <TextArea fx:id="txt_field_day2" editable="false" prefHeight="200.0" prefWidth="200.0" text="Tag 2">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </TextArea>
                  <TextArea fx:id="txt_field_day3" editable="false" prefHeight="200.0" prefWidth="200.0" text="Tag 3">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </TextArea>
                  <TextArea fx:id="txt_field_day4" editable="false" prefHeight="200.0" prefWidth="200.0" text="Tag 4">
                     <HBox.margin>
                        <Insets right="10.0" />
                     </HBox.margin>
                  </TextArea>
                  <TextArea fx:id="txt_field_day5" editable="false" prefHeight="200.0" prefWidth="200.0" text="Tag 5" />
               </children>
            </HBox>
            <HBox prefHeight="24.0" prefWidth="580.0">
               <children>
                  <Button fx:id="btn_report" mnemonicParsing="false" onAction="#onReport" prefHeight="25.0" prefWidth="118.0" text="Download Report">
                     <HBox.margin>
                        <Insets right="10.0" top="5.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="btn_offline" mnemonicParsing="false" onAction="#onOffline" text="Offline Mode">
                     <HBox.margin>
                        <Insets right="10.0" top="5.0" />
                     </HBox.margin>
                  </Button>
                  <MenuButton fx:id="menu_unit" mnemonicParsing="false" text="Unit">
                    <items>
                      <MenuItem fx:id="menu_item_c" mnemonicParsing="false" onAction="#onUnitC" text="°C" />
                      <MenuItem fx:id="menu_item_f" mnemonicParsing="false" onAction="#onUnitF" text="°F" />
                    </items>
                     <HBox.margin>
                        <Insets right="10.0" top="5.0" />
                     </HBox.margin>
                  </MenuButton>
                  <CheckBox fx:id="check_feels_like" mnemonicParsing="false" onAction="#onCheckFeelsLike" text="Feels Like">
                     <HBox.margin>
                        <Insets right="10.0" top="8.5" />
                     </HBox.margin>
                  </CheckBox>
                  <CheckBox fx:id="check_humidity" mnemonicParsing="false" onAction="#onCheckHumidity" text="Humidity">
                     <HBox.margin>
                        <Insets right="10.0" top="8.5" />
                     </HBox.margin>
                  </CheckBox>
                  <CheckBox fx:id="check_wind" mnemonicParsing="false" onAction="#onCheckWind" text="Wind">
                     <HBox.margin>
                        <Insets top="8.5" />
                     </HBox.margin>
                  </CheckBox>
               </children>
            </HBox>
         </children>
         <BorderPane.margin>
            <Insets top="10.0" />
         </BorderPane.margin>
      </VBox>
   </center>
</BorderPane>
